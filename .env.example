# ============================================================
# AI INTIME ARCHITECT — Environment variables
# ============================================================
# Copy this file to `.env.local` and fill in values as the
# backend phase is built out. None of these are used by the v1
# frontend — all generation is mocked client-side.
# ============================================================

# --- LLM ------------------------------------------------------
# Used by the generation API route to write the executive brief,
# agent blueprint, and phasing recommendations.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Retrieval (RAG over AI Intime's private corpus) ----------
# Grounds every generation on AI Intime's real docs, customer
# material, and architecture references.
PINECONE_API_KEY=
PINECONE_INDEX=ai-intime-corpus
PINECONE_ENVIRONMENT=

# --- Embeddings ----------------------------------------------
# Used once during corpus ingestion and per-request for query
# embedding.
OPENAI_API_KEY=

# --- Storage for generated PDFs ------------------------------
# Vercel Blob, S3, or similar. Only needed once PDF generation
# is wired on the backend.
BLOB_READ_WRITE_TOKEN=

# --- Optional: analytics / notifications ---------------------
# Posts high-fit submissions to Slack for the sales team.
SLACK_WEBHOOK_URL=
